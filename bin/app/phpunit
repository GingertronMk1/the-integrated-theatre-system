#!/usr/bin/env sh

TESTENV="test"

# Do this first to clear up any crap
./bin/app/console doctrine:database:drop -e $TESTENV --force

./bin/app/console doctrine:database:create -e $TESTENV \
&& ./bin/app/console doctrine:migrations:migrate -e $TESTENV --no-interaction \
&& ./bin/app/composer phpunit "$@" \
&& ./bin/app/console doctrine:migrations:migrate first -e $TESTENV --no-interaction \
&& ./bin/app/console doctrine:database:drop -e $TESTENV --force
