{
    "plugins": ["@shufo/prettier-plugin-blade"],
    "overrides": [
    {
      "files": ["*.blade.php"],
      "options": {
        "parser": "blade",
        "tabWidth": 4
      },
      "rules": {
        "printWidth": 80,
        "wrapAttributes": "force",
        "sortHtmlAttributes": "code-guide",
      }
    }
  ]
}
