<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <title>{% block title %}Welcome!{% endblock %}</title>
        {{ encore_entry_script_tags('app') }}
        {{ encore_entry_link_tags('app') }}

        {% block javascripts %}
        <!-- importmap -->
{% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}
    </head>
    <body>
        {% include 'components/header.html.twig' %}
        <main class="main">
            <div class="main__inner">
                {% block body %}{% endblock %}
            </div>
        </main>
    </body>
</html>
