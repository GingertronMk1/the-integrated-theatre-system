{% extends 'layouts/base.html.twig' %}

{% block body %}
    <h1>Welcome to The Integrated Theatre System</h1>

    <div class="row">
        <div class="col-6">
            <div class="card">
                <div class="card-header">
                    History
                </div>
                <div class="card-body">
                    We have records of {{ shows|length }} {{ shows|length == 1 ? 'show' : 'shows' }},
                    across {{ seasons|length }} {{ seasons|length == 1 ? 'season' : 'seasons' }},
                    with {{ people|length }} {{ people|length == 1 ? 'person' : 'people' }} working on them
                </div>
            </div>
        </div>
        <div class="col-6">
            <div class="card">
                <div class="card-header">Training</div>
                <div class="card-body">
                    We have records of {{ trainingItems|length }} things to be trained on, 
                    across {{ trainingCategories|length }} categories,
                    with {{ trainingSessions|length }} sessions making sure everyone's up to speed
                </div>
            </div>
        </div>
    </div>
{% endblock %}
